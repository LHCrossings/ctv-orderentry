# Normalize all text files to LF in the repo — stops the CRLF churn between
# the WSL and Windows checkouts (306 phantom-modified files, 2026-07-09).
* text=auto

# Windows batch files need CRLF in the working tree
*.bat text eol=crlf
*.cmd text eol=crlf

# Byte-exact files — never normalize
# (golden EDI fixtures are compared byte-for-byte; schemas/.rdl are vendor artifacts)
tests/fixtures/edi_golden/** -text
.claude/documents/tvb_xml_schemas/** -text
reports/*.rdl -text

# Binaries
*.pdf binary
*.xlsx binary
*.db binary
*.png binary
*.ico binary
*.zip binary
