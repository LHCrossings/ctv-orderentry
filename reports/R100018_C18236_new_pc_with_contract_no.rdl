<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Parameter_DataSource">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=EC2AMAZ-6J2KLLI;Initial Catalog=Etere_crossing</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>fddbfb51-96a6-4162-8067-8699842db26d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Parameter_DataSet">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <CommandText>select * from 
trf_userparameters</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="id_trfuserparameters">
          <DataField>id_trfuserparameters</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="coduser">
          <DataField>coduser</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="logoimage">
          <DataField>logoimage</DataField>
          <rd:TypeName>System.Byte[]</rd:TypeName>
        </Field>
        <Field Name="terms">
          <DataField>terms</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="bookingconf_DataSet">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@idAgenzia">
            <Value>=Parameters!idAgenzia.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@cod_user">
            <Value>=Parameters!cod_user.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@cod_userlist">
            <Value>=Parameters!cod_userlist.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@fromdate">
            <Value>=Parameters!fromdate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@todate">
            <Value>=Parameters!todate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ss.* FROM (
SELECT				
					  CAST(1 as bit) unplaced,'wlbl' provenience,Traffic_ScheduleList.PASSAGEMISS PASSAGE,
					  --COMMITTENTE
  					  C.id_anagraf COMM_CODCONTO,C.RAG_SOCIAL COMM_RAG_SOCIAL ,C.CITTA COMM_CITTA,C.VIA COMM_VIA,C.CAP COMM_CAP,C.PROVINCIA COMM_PROVINCIA,C.PART_IVA COMM_PART_IVA,C.E_MAIL COMM_E_MAIL,C.FAX COMM_FAX,
					  C.E_MAIL_INV COMM_E_MAIL_INV,C.E_MAIL_MKG COMM_E_MAIL_MKG,
					  --AGENZIA
  					  A.id_anagraf AGE_CODCONTO,A.RAG_SOCIAL AGE_RAG_SOCIAL ,A.CITTA AGE_CITTA,A.VIA AGE_VIA,A.CAP AGE_CAP,A.PROVINCIA AGE_PROVINCIA,A.PART_IVA AGE_PART_IVA,A.E_MAIL AGE_E_MAIL,A.FAX AGE_FAX,
					  A.E_MAIL_INV AGE_E_MAIL_INV,A.E_MAIL_MKG AGE_E_MAIL_MKG,
					  --UTENTE FINALE
  					  U.id_anagraf UTE_CODCONTO,U.RAG_SOCIAL UTE_RAG_SOCIAL ,U.CITTA UTE_CITTA,U.VIA UTE_VIA,U.CAP UTE_CAP,U.PROVINCIA UTE_PROVINCIA,U.PART_IVA UTE_PART_IVA,U.E_MAIL UTE_E_MAIL,U.FAX UTE_FAX,
					  U.E_MAIL_INV UTE_E_MAIL_INV,U.E_MAIL_MKG UTE_E_MAIL_MKG,
					  CONTRATTITESTATA.DESCRIZIONE,CONTRATTITESTATA.COD_CONTRATTO,CONTRATTITESTATA.DATA_ACQUISIZIONE,CONTRATTITESTATA.DATA_INIZIO, CONTRATTITESTATA.DATA_TERMINE, 
					  CONTRATTITESTATA.SCONTO_INCONDIZIONATO,CONTRATTITESTATA.RATE,CONTRATTITESTATA.RISTORNO,
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.COMMITTENTE) AS committente, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.UT_FINALE) AS enduser, 
                      A.AGENZIA AS agency, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.AGENTE1) AS agent, 
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.CENTROMEDIA) AS mediacenter,  CONTRATTIRIGHE.PRIORITA, 
                      isnull(dbo.rpt_trf_mc_getrowdesc(contrattirighe.id_contrattirighe,@idContratto), CONTRATTIRIGHE.DESCRIZIONE) AS rowdescription, dbo._FramesToSec(CONTRATTIRIGHE.DURATA, dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) 
                      AS duration, CONTRATTIRIGHE.N_PASSAGGI,dbo.trf_getprice(contrattirighe.id_contrattirighe,CONTRATTIRIGHE.IMPORTO) IMPORTO, CONTRATTITESTATA.PERC_SCONTO, TABELLEIVA.ALIQUOTA, 
                      CONTRATTIRIGHE.PRENOTAZIONE, CONTRATTIRIGHE.CONTROLLACAPOFILA, CONTRATTIRIGHE.CONTROLLAFINEFILA, 
                      Users.nome,Users.cod_user, dbo.rpt_trf_getScheduleTYpe(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduletype, 
                      dbo.rpt_trf_getSelectedDay(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduleDays, CONTRATTIRIGHE.ID_CONTRATTIRIGHE, 
                      0 AS costValue, '' AS costDesc, 
                      dbo.rpt_trf_getBlockNameList(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS blocklist, CONTRATTIRIGHE.P_AGENTE1,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Production') totalproduction,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Dubbing') totaldubbing,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_INIZIOF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timefrom,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_FINEF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timeto,
                      BC.code bookingcode,CONTRATTIRIGHE.DATESTART,CONTRATTIRIGHE.DATEEND,
                      null AS  dateschedule,
                      '' AS  dateschedulep,                      
                      '' as roundtimeschedule,
                      '' as roundtimeschedulep,                      
                      '' AS keynr,'' AS spotname,NULL AS eventtype,contrattirighe.tipofiller,
                      contrattirighe.SPLIT,
                      dbo.Trf_GetEventScheduleType(contrattirighe.id_contrattirighe) rowtype,
                      '' as airtimep                                         
FROM         Traffic_ScheduleList
					  INNER JOIN CONTRATTIRIGHE ON CONTRATTIRIGHE.ID_CONTRATTIRIGHE = Traffic_ScheduleList.ID_ContrattiRighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
                      LEFT OUTER JOIN Users ON CONTRATTIRIGHE.COD_USER = Users.cod_user 
                      LEFT OUTER JOIN PAGAMENTI ON CONTRATTITESTATA.ID_PAGAMENTI = PAGAMENTI.ID_PAGAMENTI 
                      LEFT OUTER JOIN TABELLEIVA ON CONTRATTITESTATA.IVA = TABELLEIVA.ID_TABELLEIVA
                      LEFT OUTER JOIN ANAGRAF C ON C.ID_ANAGRAF=CONTRATTITESTATA.COMMITTENTE
                      LEFT OUTER JOIN ANAGRAF A ON A.ID_ANAGRAF=CONTRATTITESTATA.AGENZIA
					  LEFT OUTER JOIN ANAGRAF U ON U.ID_ANAGRAF=CONTRATTITESTATA.UT_FINALE
					  LEFT OUTER JOIN ANAGRAF AG ON AG.ID_ANAGRAF=CONTRATTITESTATA.AGENTE1
					  LEFT OUTER JOIN BANCHE ON BANCHE.ID_BANCHE=CONTRATTITESTATA.ID_BANCHE
					  LEFT OUTER JOIN trf_bookingcode BC ON BC.id_bookingcode=CONTRATTIRIGHE.ID_BOOKINGCODE
					  left join trf_contrattirigheMultiContract tmc on tmc.id_contrattitestataMaster=CONTRATTITESTATA.ID_CONTRATTITESTATA
WHERE (CONTRATTITESTATA.ID_CONTRATTITESTATA =dbo.trf_getMultiContractMaster(@idContratto) or @idContratto=-1) 
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and (tmc.id_contrattirigheMaster is null)
union all
SELECT				
					   CAST(1 as bit) unplaced,'alte' provenience,dbo.nreventschedbylevel(contrattirighe.id_contrattirighe,contrattirighe.cod_user,2001,2010) PASSAGE,
					  --COMMITTENTE
  					  C.id_anagraf COMM_CODCONTO,C.RAG_SOCIAL COMM_RAG_SOCIAL ,C.CITTA COMM_CITTA,C.VIA COMM_VIA,C.CAP COMM_CAP,C.PROVINCIA COMM_PROVINCIA,C.PART_IVA COMM_PART_IVA,C.E_MAIL COMM_E_MAIL,C.FAX COMM_FAX,
					  C.E_MAIL_INV COMM_E_MAIL_INV,C.E_MAIL_MKG COMM_E_MAIL_MKG,
					  --AGENZIA
  					  A.id_anagraf AGE_CODCONTO,A.RAG_SOCIAL AGE_RAG_SOCIAL ,A.CITTA AGE_CITTA,A.VIA AGE_VIA,A.CAP AGE_CAP,A.PROVINCIA AGE_PROVINCIA,A.PART_IVA AGE_PART_IVA,A.E_MAIL AGE_E_MAIL,A.FAX AGE_FAX,
					  A.E_MAIL_INV AGE_E_MAIL_INV,A.E_MAIL_MKG AGE_E_MAIL_MKG,
					  --UTENTE FINALE
  					  U.id_anagraf UTE_CODCONTO,U.RAG_SOCIAL UTE_RAG_SOCIAL ,U.CITTA UTE_CITTA,U.VIA UTE_VIA,U.CAP UTE_CAP,U.PROVINCIA UTE_PROVINCIA,U.PART_IVA UTE_PART_IVA,U.E_MAIL UTE_E_MAIL,U.FAX UTE_FAX,
					  U.E_MAIL_INV UTE_E_MAIL_INV,U.E_MAIL_MKG UTE_E_MAIL_MKG,
					  --
					  CONTRATTITESTATA.DESCRIZIONE,CONTRATTITESTATA.COD_CONTRATTO,CONTRATTITESTATA.DATA_ACQUISIZIONE,CONTRATTITESTATA.DATA_INIZIO, CONTRATTITESTATA.DATA_TERMINE, 
					  CONTRATTITESTATA.SCONTO_INCONDIZIONATO,CONTRATTITESTATA.RATE,CONTRATTITESTATA.RISTORNO,
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.COMMITTENTE) AS committente, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.UT_FINALE) AS enduser, 
                      A.AGENZIA AS agency, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.AGENTE1) AS agent, 
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.CENTROMEDIA) AS mediacenter,  CONTRATTIRIGHE.PRIORITA, 
                      isnull(dbo.rpt_trf_mc_getrowdesc(contrattirighe.id_contrattirighe,@idContratto), CONTRATTIRIGHE.DESCRIZIONE) AS rowdescription, dbo._FramesToSec(CONTRATTIRIGHE.DURATA, dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) 
                      AS duration, CONTRATTIRIGHE.N_PASSAGGI, dbo.trf_getprice(contrattirighe.id_contrattirighe,CONTRATTIRIGHE.IMPORTO) IMPORTO, CONTRATTITESTATA.PERC_SCONTO, TABELLEIVA.ALIQUOTA, 
                      CONTRATTIRIGHE.PRENOTAZIONE, CONTRATTIRIGHE.CONTROLLACAPOFILA, CONTRATTIRIGHE.CONTROLLAFINEFILA, 
                      Users.nome,Users.cod_user, dbo.rpt_trf_getScheduleTYpe(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduletype, 
                      dbo.rpt_trf_getSelectedDay(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduleDays, CONTRATTIRIGHE.ID_CONTRATTIRIGHE, 
                      0 AS costValue, '' AS costDesc, 
                      dbo.rpt_trf_getBlockNameList(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS blocklist, CONTRATTIRIGHE.P_AGENTE1,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Production') totalproduction,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Dubbing') totaldubbing,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_INIZIOF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timefrom,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_FINEF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timeto,
                      BC.code bookingcode,CONTRATTIRIGHE.DATESTART,CONTRATTIRIGHE.DATEEND,
                      ttp.Data AS  dateschedule,
                      '' AS  dateschedulep,                      
                      '' as roundtimeschedule,
                      '' as roundtimeschedulep,                      
                      '' AS keynr,'' AS spotname,NULL AS eventtype,contrattirighe.tipofiller,
                      contrattirighe.SPLIT,
                      dbo.Trf_GetEventScheduleType(contrattirighe.id_contrattirighe) rowtype,
                      '' as airtimep                                         
FROM         		  CONTRATTIRIGHE 
					  join trafficTpalinse ttp with(nolock) on ttp.id_contrattirighe=contrattirighe.id_contrattirighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
                      LEFT OUTER JOIN Users ON CONTRATTIRIGHE.COD_USER = Users.cod_user 
                      LEFT OUTER JOIN PAGAMENTI ON CONTRATTITESTATA.ID_PAGAMENTI = PAGAMENTI.ID_PAGAMENTI 
                      LEFT OUTER JOIN TABELLEIVA ON CONTRATTITESTATA.IVA = TABELLEIVA.ID_TABELLEIVA
                      LEFT OUTER JOIN ANAGRAF C ON C.ID_ANAGRAF=CONTRATTITESTATA.COMMITTENTE
                      LEFT OUTER JOIN ANAGRAF A ON A.ID_ANAGRAF=CONTRATTITESTATA.AGENZIA
					  LEFT OUTER JOIN ANAGRAF U ON U.ID_ANAGRAF=CONTRATTITESTATA.UT_FINALE
					  LEFT OUTER JOIN ANAGRAF AG ON AG.ID_ANAGRAF=CONTRATTITESTATA.AGENTE1
					  LEFT OUTER JOIN BANCHE ON BANCHE.ID_BANCHE=CONTRATTITESTATA.ID_BANCHE
					  LEFT OUTER JOIN trf_bookingcode BC ON BC.id_bookingcode=CONTRATTIRIGHE.ID_BOOKINGCODE
					  left join trf_contrattirigheMultiContract tmc on tmc.id_contrattitestataMaster=CONTRATTITESTATA.ID_CONTRATTITESTATA
WHERE (CONTRATTITESTATA.ID_CONTRATTITESTATA =dbo.trf_getMultiContractMaster(@idContratto) or @idContratto=-1) and (tmc.id_contrattitestataMaster  is null)
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and ((ttp.Livello &gt;= 2001 and ttp.Livello &lt;= 2010) or (ttp.Livello=666) or (ttp.livello=30000) or (ttp.livello=10000))
union ALL
SELECT				  
					  CAST(0 as bit) unplaced,'' provenience,1 AS PASSAGE,
					  --COMMITTENTE
  					  C.id_anagraf COMM_CODCONTO,C.RAG_SOCIAL COMM_RAG_SOCIAL ,C.CITTA COMM_CITTA,C.VIA COMM_VIA,C.CAP COMM_CAP,C.PROVINCIA COMM_PROVINCIA,C.PART_IVA COMM_PART_IVA,C.E_MAIL COMM_E_MAIL,C.FAX COMM_FAX,
					  C.E_MAIL_INV COMM_E_MAIL_INV,C.E_MAIL_MKG COMM_E_MAIL_MKG,
					  --AGENZIA
  					  A.id_anagraf AGE_CODCONTO,A.RAG_SOCIAL AGE_RAG_SOCIAL ,A.CITTA AGE_CITTA,A.VIA AGE_VIA,A.CAP AGE_CAP,A.PROVINCIA AGE_PROVINCIA,A.PART_IVA AGE_PART_IVA,A.E_MAIL AGE_E_MAIL,A.FAX AGE_FAX,
					  A.E_MAIL_INV AGE_E_MAIL_INV,A.E_MAIL_MKG AGE_E_MAIL_MKG,
					  --UTENTE FINALE
  					  U.id_anagraf UTE_CODCONTO,U.RAG_SOCIAL UTE_RAG_SOCIAL ,U.CITTA UTE_CITTA,U.VIA UTE_VIA,U.CAP UTE_CAP,U.PROVINCIA UTE_PROVINCIA,U.PART_IVA UTE_PART_IVA,U.E_MAIL UTE_E_MAIL,U.FAX UTE_FAX,
					  U.E_MAIL_INV UTE_E_MAIL_INV,U.E_MAIL_MKG UTE_E_MAIL_MKG,
					  --
					  CONTRATTITESTATA.DESCRIZIONE,CONTRATTITESTATA.COD_CONTRATTO,CONTRATTITESTATA.DATA_ACQUISIZIONE,CONTRATTITESTATA.DATA_INIZIO, CONTRATTITESTATA.DATA_TERMINE, 
					  CONTRATTITESTATA.SCONTO_INCONDIZIONATO,CONTRATTITESTATA.RATE,CONTRATTITESTATA.RISTORNO,
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.COMMITTENTE) AS committente, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.UT_FINALE) AS enduser, 
                      A.AGENZIA AS agency, dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.AGENTE1) AS agent, 
                      dbo.rpt_trf_getRagSoc(CONTRATTITESTATA.CENTROMEDIA) AS mediacenter,  CONTRATTIRIGHE.PRIORITA, 
                      CONTRATTIRIGHE.DESCRIZIONE AS rowdescription, dbo._FramesToSec(TRAFFICTPALINSEREPORT.Duration, dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) 
                      AS duration, CONTRATTIRIGHE.N_PASSAGGI, dbo.trf_getprice(contrattirighe.id_contrattirighe,CONTRATTIRIGHE.IMPORTO) IMPORTO, CONTRATTITESTATA.PERC_SCONTO, TABELLEIVA.ALIQUOTA, 
                      CONTRATTIRIGHE.PRENOTAZIONE, CONTRATTIRIGHE.CONTROLLACAPOFILA, CONTRATTIRIGHE.CONTROLLAFINEFILA, 
                      Users.nome,Users.cod_user, dbo.rpt_trf_getScheduleTYpe(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduletype, 
                      dbo.rpt_trf_getSelectedDay(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS scheduleDays, CONTRATTIRIGHE.ID_CONTRATTIRIGHE, 
                      0 AS costValue, '' AS costDesc, 
                      dbo.rpt_trf_getBlockNameList(CONTRATTIRIGHE.ID_CONTRATTIRIGHE) AS blocklist, CONTRATTIRIGHE.P_AGENTE1,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Production') totalproduction,
                      dbo.rpt_trf_getCostSumByCategory(CONTRATTITESTATA.ID_CONTRATTITESTATA,'Dubbing') totaldubbing,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_INIZIOF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timefrom,
                      dbo._fn_hm(CONTRATTIRIGHE.ORA_FINEF,dbo.getVideoStandard(CONTRATTIRIGHE.COD_USER)) timeto,
                      BC.code bookingcode,CONTRATTIRIGHE.DATESTART,CONTRATTIRIGHE.DATEEND,
                      TRAFFICTPALINSEREPORT.Data dateschedule,
					  TRAFFICTPALINSEREPORT.data_p dateschedulep,                      
                      CONVERT(VARCHAR(5),dbo.TRF_ROUNDTIME(TRAFFICTPALINSEREPORT.Data,TRAFFICTPALINSEREPORT.Ora,TRAFFICTPALINSEREPORT.Cod_User),108) roundtimeschedule,
  					  CONVERT(VARCHAR(5),dbo.TRF_ROUNDTIME(TRAFFICTPALINSEREPORT.Data,TRAFFICTPALINSEREPORT.Ora_p,TRAFFICTPALINSEREPORT.Cod_User),108) roundtimeschedulep,                      
                      FILMATI.COD_PROGRA keynr,FILMATI.DESCRIZIO AS spotname,TRAFFICTPALINSEREPORT.eventtype,contrattirighe.tipofiller,
                      contrattirighe.SPLIT,dbo.Trf_GetEventScheduleType(contrattirighe.id_contrattirighe) rowtype,
                      dbo._fn_hms(TRAFFICTPALINSEREPORT.ora,dbo.getVideoStandard(TRAFFICTPALINSEREPORT.cod_user)) as airtime                                                          
FROM         TRAFFICTPALINSE TRAFFICTPALINSEREPORT
					  INNER JOIN CONTRATTIRIGHE ON CONTRATTIRIGHE.ID_CONTRATTIRIGHE = TRAFFICTPALINSEREPORT.ID_ContrattiRighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
                      LEFT OUTER JOIN Users ON CONTRATTIRIGHE.COD_USER = Users.cod_user 
                      LEFT OUTER JOIN PAGAMENTI ON CONTRATTITESTATA.ID_PAGAMENTI = PAGAMENTI.ID_PAGAMENTI 
                      LEFT OUTER JOIN TABELLEIVA ON CONTRATTITESTATA.IVA = TABELLEIVA.ID_TABELLEIVA
                      LEFT OUTER JOIN ANAGRAF C ON C.ID_ANAGRAF=CONTRATTITESTATA.COMMITTENTE
                      LEFT OUTER JOIN ANAGRAF A ON A.ID_ANAGRAF=CONTRATTITESTATA.AGENZIA
					  LEFT OUTER JOIN ANAGRAF U ON U.ID_ANAGRAF=CONTRATTITESTATA.UT_FINALE
					  LEFT OUTER JOIN ANAGRAF AG ON AG.ID_ANAGRAF=CONTRATTITESTATA.AGENTE1
					  LEFT OUTER JOIN BANCHE ON BANCHE.ID_BANCHE=CONTRATTITESTATA.ID_BANCHE
					  LEFT OUTER JOIN trf_bookingcode BC ON BC.id_bookingcode=CONTRATTIRIGHE.ID_BOOKINGCODE
					  LEFT OUTER JOIN FILMATI ON FILMATI.ID_FILMATI=TRAFFICTPALINSEREPORT.ID_Filmati
					  left join trf_contrattirigheMultiContract tmc on tmc.id_contrattitestataMaster=CONTRATTITESTATA.ID_CONTRATTITESTATA
WHERE     ((TRAFFICTPALINSEREPORT.ID_CONTRATTITESTATA=@idContratto or @idContratto=-1) 
and TRAFFICTPALINSEREPORT.eventtype=0 and livello=0 
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and (TRAFFICTPALINSEREPORT.cod_user=@cod_user or TRAFFICTPALINSEREPORT.cod_user in (select item from dbo.SplitTable(@cod_userlist,',')))) 
) SS
WHERE 
((@fromdate is null or SS.dateschedule&gt;=@fromdate or SS.dateschedule is null) and (@todate is null or SS.dateschedule&lt;=@todate or SS.dateschedule is null))
ORDER BY SS.id_contrattirighe,SS.airtimep,SS.datestart,SS.dateschedule,SS.roundtimeschedule,SS.cod_user,SS.provenience</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COMM_CODCONTO">
          <DataField>COMM_CODCONTO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="provenience">
          <DataField>provenience</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="unplaced">
          <DataField>unplaced</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="PASSAGE">
          <DataField>PASSAGE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COMM_RAG_SOCIAL">
          <DataField>COMM_RAG_SOCIAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="id_contrattirighe">
          <DataField>ID_CONTRATTIRIGHE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COMM_CITTA">
          <DataField>COMM_CITTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_VIA">
          <DataField>COMM_VIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_CAP">
          <DataField>COMM_CAP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IMPORTO">
          <DataField>IMPORTO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="COMM_PROVINCIA">
          <DataField>COMM_PROVINCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_PART_IVA">
          <DataField>COMM_PART_IVA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_E_MAIL">
          <DataField>COMM_E_MAIL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_FAX">
          <DataField>COMM_FAX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMM_E_MAIL_INV">
          <DataField>COMM_E_MAIL_INV</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
