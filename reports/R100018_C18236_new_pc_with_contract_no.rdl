                    <TablixCell>
                      <CellContents>
                        <Textbox Name="bookingcode2">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIf(Fields!unplaced.Value=false, 
  IIf(
    (IsNothing(Fields!spotname.Value) OrElse Fields!spotname.Value = "" OrElse Trim(Fields!spotname.Value) = "") AndAlso 
    (IsNothing(Fields!keynr.Value) OrElse Fields!keynr.Value = "" OrElse Trim(Fields!keynr.Value) = ""), 
    "NEED COPY", 
    IIf(
      IsNothing(Fields!spotname.Value) OrElse Fields!spotname.Value = "" OrElse Trim(Fields!spotname.Value) = "", 
      Fields!keynr.Value, 
      IIf(
        IsNothing(Fields!keynr.Value) OrElse Fields!keynr.Value = "" OrElse Trim(Fields!keynr.Value) = "", 
        Fields!spotname.Value, 
        IIf(InStr(Fields!spotname.Value, Fields!keynr.Value) &gt; 0, Fields!spotname.Value, Fields!spotname.Value &amp; " (" &amp; Fields!keynr.Value &amp; ")")
      )
    )
  ), 
  ""
)</Value>
                                  <Style>
                                    <FontSize>7pt</FontSize>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
