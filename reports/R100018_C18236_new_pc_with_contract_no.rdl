            <Value>=Parameters!cod_user.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@params_xml">
            <Value>=Parameters!params_xml.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select cod_user, nome, TickaSecond, VideoStandard, icona, RptBrand,
                title1, title2, cl_header, cl_footer, cl_row0, cl_row1, cl_table_header
 from dbo.rpt_loadEnv(@cod_user, @params_xml)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
