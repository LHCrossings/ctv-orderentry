    <DataSet Name="Proposal_Total_Dataset">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@fromdate">
            <Value>=Parameters!fromdate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@cod_userlist">
            <Value>=Parameters!cod_userlist.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@todate">
            <Value>=Parameters!todate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT sum(dbo.trf_calcAmmountContractByIdContractDateRange(item,@idContratto,-1,@fromdate,@todate)) as totalcontract
from dbo.SplitTable(@cod_userlist,',')</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="totalcontract">
          <DataField>totalcontract</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSetTotpassaggi">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@idAgenzia">
            <Value>=Parameters!idAgenzia.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@cod_user">
            <Value>=Parameters!cod_user.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@cod_userlist">
            <Value>=Parameters!cod_userlist.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	count(*) as TOTPASSAGGI
FROM         TRAFFICTPALINSE TRAFFICTPALINSEREPORT
					  INNER JOIN CONTRATTIRIGHE ON CONTRATTIRIGHE.ID_CONTRATTIRIGHE = TRAFFICTPALINSEREPORT.ID_ContrattiRighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
WHERE     ((TRAFFICTPALINSEREPORT.ID_CONTRATTITESTATA=@idContratto or @idContratto=-1) 
and TRAFFICTPALINSEREPORT.eventtype=0 and livello=0 
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and (TRAFFICTPALINSEREPORT.cod_user=@cod_user or TRAFFICTPALINSEREPORT.cod_user in (select item from dbo.SplitTable(@cod_userlist,','))))</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TOTPASSAGGI">
          <DataField>TOTPASSAGGI</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet_TotalWLBL">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@idAgenzia">
            <Value>=Parameters!idAgenzia.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	count(*) as totalinWLBL
FROM         Traffic_ScheduleList
					  INNER JOIN CONTRATTIRIGHE ON CONTRATTIRIGHE.ID_CONTRATTIRIGHE = Traffic_ScheduleList.ID_ContrattiRighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
                      LEFT OUTER JOIN Users ON CONTRATTIRIGHE.COD_USER = Users.cod_user 
					  left join trf_contrattirigheMultiContract tmc on tmc.id_contrattitestataMaster=CONTRATTITESTATA.ID_CONTRATTITESTATA
WHERE (CONTRATTITESTATA.ID_CONTRATTITESTATA =dbo.trf_getMultiContractMaster(@idContratto) or @idContratto=-1) 
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and (tmc.id_contrattirigheMaster is null)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="totalinWLBL">
          <DataField>totalinWLBL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet_totalepalalte">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@idAgenzia">
            <Value>=Parameters!idAgenzia.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	count(*) as totalinPALALTE
FROM         		  CONTRATTIRIGHE 
					  join trafficTpalinse ttp with(nolock) on ttp.id_contrattirighe=contrattirighe.id_contrattirighe
					  INNER JOIN CONTRATTITESTATA ON CONTRATTITESTATA.ID_CONTRATTITESTATA = CONTRATTIRIGHE.ID_CONTRATTITESTATA 
                      LEFT OUTER JOIN Users ON CONTRATTIRIGHE.COD_USER = Users.cod_user 
					  left join trf_contrattirigheMultiContract tmc on tmc.id_contrattitestataMaster=CONTRATTITESTATA.ID_CONTRATTITESTATA
WHERE (CONTRATTITESTATA.ID_CONTRATTITESTATA =dbo.trf_getMultiContractMaster(@idContratto) or @idContratto=-1) and (tmc.id_contrattitestataMaster  is null)
and (isnull(CONTRATTITESTATA.AGENZIA,0)=@idAgenzia or @idAgenzia=-1)
and ((ttp.Livello &gt;= 2001 and ttp.Livello &lt;= 2010) or (ttp.Livello=666) or (ttp.livello=30000) or (ttp.livello=10000))</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="totalinPALALTE">
          <DataField>totalinPALALTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="agencydesc">
      <Query>
        <DataSourceName>Parameter_DataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idContratto">
            <Value>=Parameters!idContratto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@idAgenzia">
            <Value>=Parameters!idAgenzia.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>if (@idContratto&gt;0)
SELECT isnull(a.rag_social,'') agedesc,
a.via agevia,
a.citta agecitta
from anagraf a
join contrattitestata c on c.agenzia=a.id_anagraf
where c.id_contrattitestata=@idContratto
if (@idAgenzia&gt;0)
SELECT isnull(rag_social,'') agedesc,
via agevia,
citta agecitta
from anagraf where id_anagraf=@idAgenzia</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="agedesc">
          <DataField>agedesc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="agevia">
          <DataField>agevia</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="agecitta">
          <DataField>agecitta</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
